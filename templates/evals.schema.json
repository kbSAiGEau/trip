{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evals.schema.json",
  "title": "Evals",
  "description": "Schema for the evaluation suite used by the Agentic Workflow Prompt Framework. Generated in Phase 2 before any code is written.",
  "type": "object",
  "required": ["project_name", "last_updated", "summary", "rules", "quality_criteria", "testing_protocol", "feature_evals", "integration_evals", "non_functional_evals", "change_log"],
  "properties": {
    "_template_meta": {
      "type": "object",
      "description": "Metadata about the template itself. Stripped when instantiated for a real project.",
      "properties": {
        "version": { "type": "string" },
        "customisation": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "project_name": {
      "type": "string"
    },
    "last_updated": {
      "type": "string",
      "description": "ISO 8601 timestamp of the last update."
    },
    "summary": {
      "type": "object",
      "required": ["total_scenarios", "passing", "failing", "not_yet_tested"],
      "properties": {
        "total_scenarios": { "type": "integer", "minimum": 0 },
        "passing": { "type": "integer", "minimum": 0 },
        "failing": { "type": "integer", "minimum": 0 },
        "not_yet_tested": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "rules": {
      "type": "object",
      "required": ["when_generated", "how_linked", "when_validated", "adding_evals", "deprecation", "test_protection"],
      "properties": {
        "when_generated": { "type": "string" },
        "how_linked": { "type": "string" },
        "when_validated": { "type": "string" },
        "adding_evals": { "type": "string" },
        "deprecation": { "type": "string" },
        "test_protection": { "type": "string" }
      },
      "additionalProperties": false
    },
    "quality_criteria": {
      "type": "object",
      "required": ["description", "standards"],
      "properties": {
        "description": { "type": "string" },
        "standards": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["good", "bad"],
            "properties": {
              "good": { "type": "string" },
              "bad": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "testing_protocol": {
      "type": "object",
      "required": ["tool", "approach", "instructions"],
      "properties": {
        "tool": { "type": "string" },
        "approach": { "type": "string" },
        "instructions": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "feature_evals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feature_eval"
      }
    },
    "integration_evals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/integration_eval"
      }
    },
    "non_functional_evals": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_functional_eval"
      }
    },
    "change_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/change_log_entry"
      },
      "description": "Append-only log of all changes to evals. Evals are never deleted, only deprecated."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "eval_status": {
      "type": "string",
      "enum": ["NOT_TESTED", "PASS", "FAIL", "DEPRECATED"],
      "description": "Status of an individual eval scenario."
    },
    "eval_scenario": {
      "type": "object",
      "required": ["id", "scenario", "input_setup", "expected_output", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique eval ID (e.g., 'FE-001-HP-01', 'FE-001-EC-02')."
        },
        "scenario": {
          "type": "string",
          "description": "What is being tested."
        },
        "input_setup": {
          "type": "string",
          "description": "Specific input or precondition state."
        },
        "expected_output": {
          "type": "string",
          "description": "Exact expected result."
        },
        "test_file": {
          "type": ["string", "null"],
          "description": "Path to the test file implementing this eval. Null before the RED stage creates the test file. Populated by /tdd during the RED stage."
        },
        "status": {
          "$ref": "#/$defs/eval_status"
        }
      },
      "additionalProperties": false
    },
    "feature_eval": {
      "type": "object",
      "required": ["id", "feature_name", "derived_from", "happy_path", "edge_cases", "failure_modes"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Feature eval group ID (e.g., 'FE-001')."
        },
        "feature_name": { "type": "string" },
        "derived_from": {
          "type": "string",
          "description": "PRD section and user story reference (e.g., 'PRD Section 3.1, US-001')."
        },
        "happy_path": {
          "type": "array",
          "items": { "$ref": "#/$defs/eval_scenario" },
          "minItems": 1
        },
        "edge_cases": {
          "type": "array",
          "items": { "$ref": "#/$defs/eval_scenario" }
        },
        "failure_modes": {
          "type": "array",
          "items": { "$ref": "#/$defs/eval_scenario" }
        }
      },
      "additionalProperties": false
    },
    "integration_eval": {
      "type": "object",
      "required": ["id", "scenario", "components_involved", "expected_behaviour", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Integration eval ID (e.g., 'INT-001')."
        },
        "scenario": { "type": "string" },
        "components_involved": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expected_behaviour": { "type": "string" },
        "test_file": { "type": ["string", "null"] },
        "status": { "$ref": "#/$defs/eval_status" }
      },
      "additionalProperties": false
    },
    "non_functional_eval": {
      "type": "object",
      "required": ["id", "category", "scenario", "threshold", "status"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Non-functional eval ID (e.g., 'NF-001')."
        },
        "category": {
          "type": "string",
          "description": "Category (e.g., 'Performance', 'Security', 'Accessibility')."
        },
        "scenario": { "type": "string" },
        "threshold": {
          "type": "string",
          "description": "Pass/fail threshold (e.g., '< 200ms', 'Rejected', 'All elements labelled')."
        },
        "test_file": {
          "type": ["string", "null"],
          "description": "Path to the test file implementing this eval. Null before the RED stage creates the test file."
        },
        "status": { "$ref": "#/$defs/eval_status" }
      },
      "additionalProperties": false
    },
    "change_log_entry": {
      "type": "object",
      "required": ["date", "eval_id", "change_type", "description"],
      "properties": {
        "date": {
          "type": "string",
          "description": "ISO 8601 date (e.g., '2026-03-29')."
        },
        "task_id": {
          "type": ["string", "null"],
          "description": "Roadmap task ID that triggered this change (e.g., '1.2'). Null for initial generation."
        },
        "eval_id": {
          "type": "string",
          "description": "The eval ID affected by this change."
        },
        "change_type": {
          "type": "string",
          "enum": ["CREATED", "UPDATED", "DEPRECATED", "STATUS_CHANGE"],
          "description": "Type of change made to the eval."
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of the change."
        }
      },
      "additionalProperties": false
    }
  }
}
